<%- include('../layouts/header') %>
<h2>AI Pre-Visit Summary</h2>
<div class="card">
  <h3>Patient's Symptoms</h3>
  <p><%= data.symptoms %></p>

  <% if (data.summary) { %>
    <div class="summary-section urgency-<%= data.summary.urgency_level?.toLowerCase() %>">
      <h3>Urgency Level: <%= data.summary.urgency_level %></h3>
    </div>
    <div class="summary-section">
      <h3>Chief Complaint</h3>
      <p><%= data.summary.chief_complaint %></p>
    </div>
    <div class="summary-section">
      <h3>Suggested Questions for the Patient</h3>
      <ul>
        <% if (data.summary.suggested_questions) { %>
          <% data.summary.suggested_questions.forEach(function(q) { %>
            <li><%= q %></li>
          <% }); %>
        <% } %>
      </ul>
    </div>
  <% } else { %>
    <p>AI summary not available.</p>
  <% } %>

  <a href="/doctor/appointments/<%= data.appointment_id %>" class="btn btn-primary">Back</a>
</div>
<%- include('../layouts/footer') %>

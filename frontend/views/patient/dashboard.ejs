<%- include('../layouts/header') %>
<h2>Patient Dashboard</h2>
<div class="dashboard-grid">
  <div class="card">
    <h3>Quick Actions</h3>
    <div style="display: flex; gap: 10px; flex-wrap: wrap;">
      <a href="/patient/doctors" class="btn btn-primary">Book New Appointment</a>
      <a href="/patient/google/link" class="btn btn-secondary" style="background: #ffffff; color: #3c4043; border-color: #dadce0; display: inline-flex; align-items: center; gap: 8px;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M19 4H5C3.89 4 3.01 4.9 3.01 6L3 20C3 21.1 3.89 22 5 22H19C20.1 22 21 21.1 21 20V6C21 4.9 20.1 4.85 19 4.85V4ZM19 20H5V9H19V20ZM19 7H5V6H19V7ZM12 11H7V16H12V11Z" fill="#1a73e8"/>
        </svg>
        Link Google Calendar
      </a>
    </div>
  </div>

  <div class="card">
    <h3>My Appointments</h3>
    <% if (appointments && appointments.length > 0) { %>
      <div class="table-responsive">
        <table class="table">
          <thead>
            <tr>
              <th>Doctor</th>
              <th>Date</th>
              <th>Time</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% appointments.forEach(function(apt) { %>
              <tr>
                <td data-label="Doctor">Dr. <%= apt.doctor_name %></td>
                <td data-label="Date"><%= apt.appointment_date %></td>
                <td data-label="Time"><%= apt.start_time %> - <%= apt.end_time %></td>
                <td data-label="Status"><span class="badge badge-<%= apt.status.toLowerCase() %>"><%= apt.status %></span></td>
                <td data-label="Actions" class="actions">
                  <% if (apt.status === 'SCHEDULED' || apt.status === 'RESCHEDULED') { %>
                    <% if (!apt.has_symptom_form) { %>
                      <a href="/patient/appointments/<%= apt.id %>/symptoms" class="btn btn-sm">Submit Symptoms</a>
                    <% } %>
                    <a href="/patient/appointments/<%= apt.id %>/reschedule/slots" class="btn btn-sm">Reschedule</a>
                    <form method="POST" action="/patient/appointments/<%= apt.id %>/cancel" style="display:inline">
                      <button type="submit" class="btn btn-sm btn-danger">Cancel</button>
                    </form>
                  <% } %>
                  <% if (apt.has_post_visit_summary) { %>
                    <a href="/patient/appointments/<%= apt.id %>/summary" class="btn btn-sm">View Summary</a>
                  <% } %>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <p>No appointments found. <a href="/patient/doctors">Book one now</a>.</p>
    <% } %>
  </div>
</div>
<%- include('../layouts/footer') %>

<script>
  const urlParams = new URLSearchParams(window.location.search);
  if (urlParams.get('calendar') === 'linked') {
    const alertDiv = document.createElement('div');
    alertDiv.className = 'alert alert-success';
    alertDiv.style.background = '#e6f4ea';
    alertDiv.style.color = '#137333';
    alertDiv.style.border = '1px solid #c4eed0';
    alertDiv.style.padding = '12px 16px';
    alertDiv.style.borderRadius = '6px';
    alertDiv.style.marginBottom = '16px';
    alertDiv.innerText = 'Google Calendar linked successfully!';
    document.querySelector('.dashboard-grid').before(alertDiv);
    window.history.replaceState({}, document.title, window.location.pathname);
  }
</script>

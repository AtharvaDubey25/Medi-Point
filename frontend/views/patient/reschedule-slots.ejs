<%- include('../layouts/header') %>
<h2>Reschedule Appointment - Dr. <%= doctor.full_name %></h2>
<p class="specialization"><%= doctor.specialization %></p>
<div class="availability-info" style="margin-bottom: 20px; font-size: 0.95rem; color: #555;">
  <span style="font-weight: 600; color: #333;">Weekly Availability:</span>
  <% 
    var weekdayNames = ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'];
    var activeDays = [];
    if (doctor.availability && doctor.availability.length > 0) {
      var daySet = new Set();
      doctor.availability.forEach(function(a) {
        if (a.is_available) {
          daySet.add(a.day_of_week);
        }
      });
      var sortedDays = Array.from(daySet).sort(function(a, b) { return a - b; });
      activeDays = sortedDays.map(function(d) { return weekdayNames[d]; });
    }
  %>
  <% if (activeDays.length > 0) { %>
    <span class="available-badge" style="background: #e6f4ea; color: #137333; padding: 4px 8px; border-radius: 4px; font-size: 0.85rem; font-weight: 500; margin-left: 8px;">
      <%= activeDays.join(', ') %>
    </span>
  <% } else { %>
    <span class="available-badge" style="background: #fce8e6; color: #c5221f; padding: 4px 8px; border-radius: 4px; font-size: 0.85rem; font-weight: 500; margin-left: 8px;">
      No weekly availability set
    </span>
  <% } %>
</div>
<p>Current appointment: <strong><%= appointment.appointment_date %> at <%= appointment.start_time %> - <%= appointment.end_time %></strong></p>

<div class="date-picker">
  <form method="GET" action="/patient/appointments/<%= appointment.id %>/reschedule/slots">
    <label>Select Date:</label>
    <input type="date" name="date" value="<%= date %>" required>
    <button type="submit" class="btn btn-primary">Check Slots</button>
  </form>
</div>

<% if (slots && slots.length > 0) { %>
  <div class="slots-grid">
    <% slots.forEach(function(slot) { %>
      <div class="slot-card <%= slot.available ? 'available' : 'booked' %>">
        <span><%= slot.start_time %> - <%= slot.end_time %></span>
        <% if (slot.available) { %>
          <a href="/patient/appointments/<%= appointment.id %>/reschedule/confirm?date=<%= date %>&time=<%= slot.start_time %>" class="btn btn-sm btn-primary">Select</a>
        <% } else { %>
          <span class="booked-label">Booked</span>
        <% } %>
      </div>
    <% }); %>
  </div>
<% } else if (date) { %>
  <p>No available slots for this date.</p>
<% } %>
<%- include('../layouts/footer') %>

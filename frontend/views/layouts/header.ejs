<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Medi Point</title>
  <link rel="icon" type="image/png" href="/favicon.png">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar">
    <div class="container">
      <a href="/" class="navbar-brand">
        <img src="/favicon.png" alt="Medi Point Logo" class="navbar-logo">
        Medi Point
      </a>
      <div class="navbar-nav">
        <% if (user) { %>
          <% if (user.role === 'PATIENT') { %>
            <a href="/patient/dashboard">Dashboard</a>
            <a href="/patient/doctors">Find Doctors</a>
          <% } else if (user.role === 'DOCTOR') { %>
            <a href="/doctor/dashboard">Appointments</a>
            <a href="/doctor/availability">Schedule</a>
          <% } else if (user.role === 'ADMIN') { %>
            <a href="/admin/dashboard">Dashboard</a>
          <% } %>
          <span class="nav-user"><%= user.full_name %> (<%= user.role %>)</span>
          <a href="/logout">Logout</a>
        <% } else { %>
          <a href="/login">Login</a>
          <a href="/register">Register</a>
        <% } %>
      </div>
    </div>
  </nav>

  <main class="container">
